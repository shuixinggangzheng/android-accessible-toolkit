<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/elder_padding_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="药物名称"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_primary"
            android:layout_marginBottom="@dimen/elder_padding_small"
            android:contentDescription="药物名称输入框标签" />

        <EditText
            android:id="@+id/et_medication_name"
            android:layout_width="match_parent"
            android:layout_height="@dimen/elder_button_height"
            android:hint="例如：降压药"
            android:inputType="text"
            android:padding="@dimen/elder_padding_medium"
            android:textSize="@dimen/elder_text_size_body"
            android:layout_marginBottom="@dimen/elder_padding_medium"
            android:minHeight="@dimen/elder_min_touch_target"
            android:contentDescription="请输入药物名称" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="剂量说明"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_primary"
            android:layout_marginBottom="@dimen/elder_padding_small"
            android:contentDescription="剂量说明输入框标签" />

        <EditText
            android:id="@+id/et_dosage"
            android:layout_width="match_parent"
            android:layout_height="@dimen/elder_button_height"
            android:hint="例如：每次1片"
            android:inputType="text"
            android:padding="@dimen/elder_padding_medium"
            android:textSize="@dimen/elder_text_size_body"
            android:layout_marginBottom="@dimen/elder_padding_medium"
            android:minHeight="@dimen/elder_min_touch_target"
            android:contentDescription="请输入剂量说明" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="提醒时间"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_primary"
            android:layout_marginBottom="@dimen/elder_padding_small"
            android:contentDescription="提醒时间区域标题" />

        <TextView
            android:id="@+id/tv_selected_times"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未设置提醒时间"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_hint"
            android:padding="@dimen/elder_padding_medium"
            android:background="@color/elder_card_background"
            android:layout_marginBottom="@dimen/elder_padding_medium"
            android:strokeColor="@color/elder_card_border"
            android:strokeWidth="@dimen/elder_border_width"
            android:contentDescription="当前设置的提醒时间" />

        <Button
            android:id="@+id/btn_add_time"
            android:layout_width="match_parent"
            android:layout_height="@dimen/elder_button_height"
            android:text="添加时间"
            android:textSize="@dimen/elder_text_size_body"
            android:layout_marginBottom="@dimen/elder_padding_medium"
            android:minHeight="@dimen/elder_min_touch_target"
            android:backgroundTint="@color/elder_button_background"
            android:textColor="@color/elder_button_text"
            android:contentDescription="点击添加提醒时间" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重复模式"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_primary"
            android:layout_marginBottom="@dimen/elder_padding_small"
            android:contentDescription="重复模式选择框标签" />

        <Spinner
            android:id="@+id/spinner_repeat_mode"
            android:layout_width="match_parent"
            android:layout_height="@dimen/elder_button_height"
            android:layout_marginBottom="@dimen/elder_padding_medium"
            android:minHeight="@dimen/elder_min_touch_target"
            android:contentDescription="请选择重复模式" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择星期（每周模式）"
            android:textSize="@dimen/elder_text_size_body"
            android:textColor="@color/elder_text_primary"
            android:layout_marginBottom="@dimen/elder_padding_small"
            android:visibility="gone"
            android:contentDescription="星期选择区域标签" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
